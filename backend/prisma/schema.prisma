generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  WORKER
  EMPLOYER
}

enum JobStatus {
  OPEN
  CLOSED
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum ContractStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

model User {
  id            Int             @id @default(autoincrement())
  email         String          @unique
  password      String
  name          String
  phone         String?
  role          Role
  avatarUrl     String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  workerProfile WorkerProfile?
  employerProfile EmployerProfile?

  jobsAsEmployer         Job[]
  applicationsAsWorker   Application[]
  contractsAsWorker      Contract[]       @relation("WorkerContracts")
  contractsAsEmployer    Contract[]       @relation("EmployerContracts")
  reviewsGiven           Review[]         @relation("ReviewAuthor")
  reviewsReceived        Review[]         @relation("ReviewTarget")
  messagesSent           Message[]        @relation("MessageSender")
  messagesReceived       Message[]        @relation("MessageReceiver")
}

model WorkerProfile {
  id           Int      @id @default(autoincrement())
  userId       Int      @unique
  bio          String?
  experience   String?
  hourlyRate   Float?
  location     String?
  availability String?
  skills       String[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmployerProfile {
  id           Int      @id @default(autoincrement())
  userId       Int      @unique
  bio          String?
  familyName   String?
  address      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Job {
  id          Int        @id @default(autoincrement())
  employerId  Int
  title       String
  description String
  location    String
  hourlyRate  Float?
  schedule    String?
  status      JobStatus  @default(OPEN)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  employer    User       @relation(fields: [employerId], references: [id], onDelete: Cascade)
  applications Application[]
  contracts   Contract[]
}

model Application {
  id          Int               @id @default(autoincrement())
  workerId    Int
  jobId       Int
  status      ApplicationStatus @default(PENDING)
  message     String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  worker      User              @relation(fields: [workerId], references: [id], onDelete: Cascade)
  job         Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([workerId, jobId])
}

model Contract {
  id          Int            @id @default(autoincrement())
  workerId    Int
  employerId  Int
  jobId       Int
  status      ContractStatus @default(ACTIVE)
  agreedRate  Float?
  startDate   DateTime       @default(now())
  endDate     DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  worker      User           @relation("WorkerContracts", fields: [workerId], references: [id], onDelete: Cascade)
  employer    User           @relation("EmployerContracts", fields: [employerId], references: [id], onDelete: Cascade)
  job         Job            @relation(fields: [jobId], references: [id], onDelete: Cascade)
  reviews     Review[]
}

model Review {
  id        Int      @id @default(autoincrement())
  authorId  Int
  targetId  Int
  contractId Int
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  author    User     @relation("ReviewAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  target    User     @relation("ReviewTarget", fields: [targetId], references: [id], onDelete: Cascade)
  contract  Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@unique([authorId, contractId])
}

model Message {
  id         Int      @id @default(autoincrement())
  senderId   Int
  receiverId Int
  content    String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  sender     User     @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   User     @relation("MessageReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
}
